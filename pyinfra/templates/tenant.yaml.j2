# tenants/{{ tenant_name }}/tenant.yaml
# Generated by scripts/new-tenant.sh on {{ created_at }}
# Schema: SPEC-001 v1.3 (multi-concierge LIST form + optional git-backed workspace)
#
# BEFORE first deploy:
#   1. Replace ALL PLACEHOLDER_* values with real ones (see comments per field)
#   2. Run scripts/operator-set-secret.sh for each entry in secrets.required_keys
#   3. Provision Hetzner box (Step 7b's pyinfra task) — that fills in host.ip etc.
#   4. Run pyinfra deploy --tenant={{ tenant_name }}

# ─── Tenant identity ────────────────────────────────────────────────
schema_version: 1
tenant_name: {{ tenant_name }}
tenant_type: {{ tenant_type }}
display_name: {{ display_name }}
contact:
  # OPERATOR: replace with the real contact email (REQUIRED for tenant_type=client).
  primary_email: ops@{{ tenant_name }}.example.com
  # OPERATOR: replace with the client's Telegram numeric user ID (string-typed).
  primary_telegram_user_id: "PLACEHOLDER_TELEGRAM_USER_ID"

# ─── Infrastructure ─────────────────────────────────────────────────
host:
  # OPERATOR: filled in automatically by Step 7b's Hetzner provision task.
  ip: PLACEHOLDER_FILL_AFTER_HETZNER_PROVISION
  hostname: {{ tenant_name }}
  ssh_user: claude
  ssh_port: 22
  os_family: linux
  os_distro: ubuntu
  os_version: "24.04"
  provider: hetzner
  # OPERATOR: filled in automatically by Step 7b's Hetzner provision task.
  provider_server_id: PLACEHOLDER_FILL_AFTER_HETZNER_PROVISION
  region: PLACEHOLDER_FILL_AFTER_HETZNER_PROVISION

# ─── Hardening profile ─────────────────────────────────────────────
hardening:
  ufw:
    enabled: true
    allow_ssh_from: any
  fail2ban:
    enabled: true
    sshd_jail: aggressive
    bans:
      maxretry: 5
      findtime_minutes: 10
      bantime_hours: 1
  sshd:
    permit_root_login: "no"
    password_authentication: "no"
    max_auth_tries: 3
  unattended_upgrades:
    enabled: true
    auto_reboot_time: "04:00"
  swap:
    enabled: true
    size_gb: 2
    swappiness: 10
  hetzner_cloud_firewall:
    enabled: true
    # OPERATOR: filled in automatically by Step 7b's Hetzner provision task.
    firewall_id: PLACEHOLDER_FILL_AFTER_HETZNER_PROVISION

# ─── Agent configuration ───────────────────────────────────────────
agent:
  install:
    claude_code: true
    nodejs_version: "22"
    bun: true

  # Box-level plugins (enabled for every concierge on this box).
  plugins:
    - telegram@claude-plugins-official

  # MULTI-CONCIERGE (SPEC-001 v1.2). `concierges` is a LIST — the canonical
  # form. A tenant box may host SEVERAL self-contained general-purpose
  # concierges; this scaffold ships ONE (a one-element list), which is the
  # common case. Add more by appending entries (see the commented example at
  # the bottom of this block). Each concierge gets its own:
  #   - systemd service   claude-agent-<name>.service
  #   - Telegram channel  (its own bot token + allowed_user_ids)
  #   - liveness watchdog telegram-watchdog-<name>.*
  #   - workdir           /home/claude/agents/<name>   (UNPREFIXED, SPEC-021 inv#6)
  # The PRIMARY (first) concierge keeps the historical runtime env path
  # /run/claude-agent/env; additional concierges decrypt into
  # /run/claude-agent-<name>/env so two concierges never clobber each other.
  concierges:
    - name: {{ persona_name }}                  # UNIQUE per tenant. Drives service/channel/watchdog names.
      persona_dir: persona/{{ persona_name }}   # Relative to this tenant dir. Must EXIST (parse-time check); must contain CLAUDE.md.
      # ── Optional GIT-BACKED workspace (SPEC-001 v1.3) ───────────────────
      # By default the concierge's workdir is SYNCED from the data-repo
      # persona/{{ persona_name }}/workspace/ tree. To instead make the workdir
      # the concierge's OWN git repo (clone-if-absent, no destructive re-sync),
      # uncomment the two lines below AND remove the persona/<name>/workspace/
      # tree (setting both is rejected at parse time — they are mutually
      # exclusive). Used by claudette, whose workspace is her own ~1GB repo.
      # workspace_repo: https://github.com/ORG/{{ persona_name }}-workspace.git
      # workspace_branch: main                  # OPTIONAL. Default "main".
      channels:
        telegram:
          enabled: true
          bot_token_secret_ref: TELEGRAM_BOT_TOKEN   # Key name in secrets.sops.env (UPPER_SNAKE_CASE).
          allowed_user_ids:
            # OPERATOR: replace with the real allowed Telegram user IDs (strings).
            - "PLACEHOLDER_TELEGRAM_USER_ID"
      llm:
        provider: anthropic
        auth_mode: claude_code_subscription
        # auth_mode=claude_code_subscription: agent uses existing Claude Code
        # login (interactive `claude login` once on the box). No API key shipped
        # via SOPS. Credentials persist in ~/.claude/.credentials.json (mode 0600).
        model: "opus[1m]"
        # Canonical auto-upgrading alias (SPEC-021 inv#1): the "opus" family
        # alias (resolves to the LATEST Opus — a deliberate auto-upgrade) plus
        # the `[1m]` 1M-context modifier. Do NOT pin a version, and do NOT use
        # bare "opus" (loses the 1M context) or the literal "default" (does not
        # resolve — was the 2026-05-31 outage root cause).
      systemd:
        restart: on-failure
        restart_sec: 10
        nofile_limit: 65536

    # ── A SECOND concierge (multi-concierge / Tenant-as-a-Service) ──────────
    # Uncomment + adapt to host another self-contained concierge on this box.
    # Names must be UNIQUE; each needs its OWN bot_token_secret_ref (add the key
    # to secrets.required_keys below + paste it via operator-set-secret.sh).
    # - name: sandra
    #   persona_dir: persona/sandra
    #   channels:
    #     telegram:
    #       enabled: true
    #       bot_token_secret_ref: SANDRA_TELEGRAM_BOT_TOKEN
    #       allowed_user_ids: ["PLACEHOLDER_TELEGRAM_USER_ID"]
    #   llm:
    #     provider: anthropic
    #     auth_mode: claude_code_subscription
    #     model: "opus[1m]"

# ─── Access ────────────────────────────────────────────────────────
access:
  tailscale:
    enabled: true
    authkey_secret_ref: TAILSCALE_AUTHKEY
    tags:
      # Must match a tag defined in tailnet ACL's tagOwners (and the auth key
      # itself must be generated WITH this tag — Tailscale enforces both).
      - "tag:bubble-tenant"
    accept_routes: false
    advertise_routes: []

  phone_home:
    enabled: true
    interval_minutes: 5

# ─── Secrets layer (SPEC-006) ──────────────────────────────────────
secrets:
  enabled: true
  age_key_path: /etc/age/key.txt
  encrypted_file_path: /etc/bubble/secrets.sops.env
  decrypted_runtime_path: /run/claude-agent/env

  # Required keys that MUST be present in the decrypted secrets.sops.env.
  # Validated at deploy time — if any missing, deploy fails before installing
  # the systemd unit (Step 4). Paste each value via:
  #   scripts/operator-set-secret.sh --tenant={{ tenant_name }} --key=<KEY>
  required_keys:
    - TELEGRAM_BOT_TOKEN
    - CLAUDE_CODE_OAUTH_TOKEN
    - TAILSCALE_AUTHKEY
    - PHONEHOME_TOKEN

# ─── Metadata ──────────────────────────────────────────────────────
created_at: "{{ created_at }}"
provisioned_by: {{ provisioned_by }}
notes: |
  Tenant scaffolded by scripts/new-tenant.sh on {{ created_at }}.
  See README.md for contract details, contact info, and onboarding checklist.
