#!/usr/bin/env bash
# /home/claude/scripts/git-credential-helper.sh
# Managed by bubble-vps-platform (SPEC-020). Do not edit by hand.
#
# Dual-mode credential helper for git, supporting both:
#
#   1. GIT_ASKPASS protocol (used by `git clone https://...`):
#      git invokes us once with a prompt arg like:
#        "Username for 'https://github.com': "
#        "Password for 'https://x-access-token@github.com': "
#      We must output a SINGLE line — the answer to the prompt. We sniff
#      "Username" vs "Password" in the prompt and emit accordingly.
#
#   2. credential.helper protocol (used by subsequent pull/push when
#      configured via `git config credential.helper '/path/to/this'`):
#      git invokes us with a subcommand on argv (get/store/erase) and
#      key=value lines on stdin. For "get" we emit `username=x-access-token`
#      and `password=$GITHUB_TOKEN` on stdout. For store/erase we no-op
#      (we don't persist anywhere — token always lives in env).
#
# SPEC-008 hard rule: token comes from the caller's env (GITHUB_TOKEN), is
# emitted on stdout to git's controlled FD, and never persisted to disk.
# git consumes it directly without passing through a shell expansion.

# Mode 1: GIT_ASKPASS — the FIRST argv looks like "Username for '...':" or
# "Password for '...':". Single-arg call.
case "${1:-}" in
    Username*|username*)
        echo "x-access-token"
        exit 0
        ;;
    Password*|password*)
        echo "${GITHUB_TOKEN:-}"
        exit 0
        ;;
esac

# Mode 2: credential.helper — argv is a subcommand (get/store/erase).
case "${1:-}" in
    get)
        echo "username=x-access-token"
        echo "password=${GITHUB_TOKEN:-}"
        exit 0
        ;;
    store|erase)
        # No-op: we don't persist credentials; the token always comes from
        # GITHUB_TOKEN in the caller's env.
        exit 0
        ;;
esac

# Unknown invocation — emit nothing, let git handle the failure.
exit 0
