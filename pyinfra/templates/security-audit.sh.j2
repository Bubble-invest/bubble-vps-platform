#
# Suppression flag: when invoked by the morty-agentic-audit cron (which runs
# THIS script as a subprocess for the deterministic data layer, then sends
# its own consolidated brief), the calling environment sets
# `AGENTIC_AUDIT_SUPPRESS_TELEGRAM=1`. In that mode we skip the direct
# Telegram post â€” findings still go to /var/log/bubble-security/, the agent
# reads them and sends the single brief. Added 2026-05-12 after the legacy
# direct-post path was confirmed as duplicate noise (both shell + agent
# crons messaging the user the same morning).
if [[ "${AGENTIC_AUDIT_SUPPRESS_TELEGRAM:-0}" == "1" ]]; then
    log "AGENTIC_AUDIT_SUPPRESS_TELEGRAM=1 â€” skipping direct Telegram post (agentic cron will send consolidated brief)"
else
    TOKEN=$(awk -F= '/^TELEGRAM_BOT_TOKEN=/{print $2; exit}' "$ENV_FILE" 2>/dev/null)
    if [[ -n "${TOKEN:-}" ]]; then
        curl -s --max-time 15 \
            "https://api.telegram.org/bot${TOKEN}/sendMessage" \
            --data-urlencode "chat_id=${JORIS_TG_USER_ID}" \
            --data-urlencode "text=${MESSAGE}" \
            > /dev/null 2>&1
        unset TOKEN
        log "posted summary to Telegram chat_id=${JORIS_TG_USER_ID}"
    else
        unset TOKEN
        log "WARN: no TELEGRAM_BOT_TOKEN in ${ENV_FILE}; skipping Telegram post"
    fi
fi

log "=== security audit done ==="
exit 0
