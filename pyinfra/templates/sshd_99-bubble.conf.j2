# Bubble Invest — SSH hardening
# Numeric prefix 00- → loaded before 50-cloud-init.conf (sshd uses last-match for most directives,
# but for the auth-mode directives below the first match wins; placing this first locks them down).
PermitRootLogin {{ permit_root_login }}
PasswordAuthentication {{ password_authentication }}
KbdInteractiveAuthentication no
ChallengeResponseAuthentication no
PubkeyAuthentication yes
PermitEmptyPasswords no
MaxAuthTries {{ max_auth_tries }}
LoginGraceTime 20
